{
  "installCommand": "npm ci && npm ci --prefix frontend-next",
  "buildCommand": "npm run check && npm run build",
  "outputDirectory": "frontend-next/out",
  "nodeVersion": "22.11.0",
  "cloudFunctions": {
    "nodejs": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/api/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, max-age=0, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
